{
  "name": "noted/php-api",
  "description": "AI + aggregation backend for the noted app",
  "type": "project",
  "require": {
    "php": ">=8.2",
    "slim/slim": "^4.13",
    "slim/psr7": "^1.6",
    "firebase/php-jwt": "^6.10",
    "guzzlehttp/guzzle": "^7.8",
    "vlucas/phpdotenv": "^5.6"
  },
  "autoload": { "psr-4": { "App\\": "src/" } },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true,
    "allow-plugins": true
  },
  "policy": {
    "advisories": {
      "ignore": ["PKSA-y2cr-5h3j-g3ys"]
    }
  }
}
